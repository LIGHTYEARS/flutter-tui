{
  "name": "flutter-tui",
  "version": "0.1.0",
  "description": "Flutter-faithful TUI framework for TypeScript — three-tree architecture with declarative widgets, box-constraint layout, and 60fps cell-level diff rendering",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "example:hello": "bun run examples/hello-world.ts",
    "example:counter": "bun run examples/counter.ts",
    "example:flex": "bun run examples/flex-layout.ts",
    "example:scroll": "bun run examples/scroll-demo.ts",
    "example:table": "bun run examples/table-demo.ts",
    "example:input": "bun run examples/input-form.ts",
    "example:todo": "bun run examples/todo-app.ts",
    "example:perf": "bun run examples/perf-stress.ts"
  },
  "keywords": ["tui", "terminal", "flutter", "widget", "ui", "cli", "render", "layout"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
